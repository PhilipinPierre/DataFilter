<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- Global Theme Resource Keys for Customization -->
    <Color x:Key="FilterPopupBackgroundColor">#FFFFFF</Color>
    <Color x:Key="FilterPopupForegroundColor">#333333</Color>
    <Color x:Key="FilterPopupBorderColor">#CCCCCC</Color>
    
    <SolidColorBrush x:Key="FilterPopupBackground" Color="{StaticResource FilterPopupBackgroundColor}" />
    <SolidColorBrush x:Key="FilterPopupForeground" Color="{StaticResource FilterPopupForegroundColor}" />
    <SolidColorBrush x:Key="FilterPopupBorder" Color="{StaticResource FilterPopupBorderColor}" />
    
    <SolidColorBrush x:Key="FilterButtonActiveColor" Color="DodgerBlue" />
    <SolidColorBrush x:Key="FilterButtonInactiveColor" Color="Gray" />

    <System:Double x:Key="FilterPopupMaxHeight">450</System:Double>

    <!-- Specific Style Overrides -->
    <Style x:Key="FilterButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#E0E0E0"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="FilterSearchBlockStyle"
           TargetType="TextBlock">
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Padding" Value="5"/>
    </Style>
    <Style x:Key="FilterExpanderStyle"
           TargetType="Expander">
        <Setter Property="Background"
                Value="#F5F5F5" />
        <Setter Property="Foreground"
                Value="#333333" />
        <Setter Property="Padding"
                Value="5" />
    </Style>
    <Style x:Key="FilterSearchBoxStyle"
           TargetType="TextBox">
        <Setter Property="Background"
                Value="#F5F5F5" />
        <Setter Property="Foreground"
                Value="#333333" />
        <Setter Property="BorderBrush"
                Value="#DDDDDD" />
        <Setter Property="Padding"
                Value="5" />
    </Style>

    <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource FilterPopupForeground}"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

</ResourceDictionary>
