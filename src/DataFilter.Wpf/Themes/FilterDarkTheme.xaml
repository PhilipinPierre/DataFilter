<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">

    <!-- Dark Theme Colors override -->
    <Color x:Key="FilterPopupBackgroundColor">#252526</Color>
    <Color x:Key="FilterPopupForegroundColor">#F1F1F1</Color>
    <Color x:Key="FilterPopupBorderColor">#3F3F46</Color>
    
    <SolidColorBrush x:Key="FilterPopupBackground" Color="{StaticResource FilterPopupBackgroundColor}" />
    <SolidColorBrush x:Key="FilterPopupForeground" Color="{StaticResource FilterPopupForegroundColor}" />
    <SolidColorBrush x:Key="FilterPopupBorder" Color="{StaticResource FilterPopupBorderColor}" />
    
    <SolidColorBrush x:Key="FilterButtonActiveColor" Color="#007ACC" />
    <SolidColorBrush x:Key="FilterButtonInactiveColor" Color="#999999" />

    <!-- Correction : Utiliser x:Key avec une valeur littérale pour Double -->
    <System:Double x:Key="FilterPopupMaxHeight">450</System:Double>

    <!-- Specific Style Overrides -->
    <Style x:Key="FilterButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#3E3E42"/>
        <Setter Property="Foreground" Value="#F1F1F1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="FilterSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#F1F1F1"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="Padding" Value="5"/>
    </Style>
    <Style x:Key="FilterSearchBlockStyle"
           TargetType="TextBlock">
        <Setter Property="Background"
                Value="#1E1E1E" />
        <Setter Property="Foreground"
                Value="#F1F1F1" />
        <Setter Property="Padding"
                Value="5" />
    </Style>
    <Style x:Key="FilterExpanderStyle"
           TargetType="Expander">
        <Setter Property="Background"
                Value="#1E1E1E" />
        <Setter Property="Foreground"
                Value="#F1F1F1" />
        <Setter Property="Padding"
                Value="5" />
    </Style>

    <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource FilterPopupForeground}"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

</ResourceDictionary>
