<UserControl x:Class="DataFilter.Wpf.Controls.FilterPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:DataFilter.Wpf.Converters"
             xmlns:behaviors="clr-namespace:DataFilter.Wpf.Behaviors"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ColumnFilterViewModel}"
             Background="{DynamicResource FilterPopupBackground}"
             Foreground="{DynamicResource FilterPopupForeground}"
             BorderBrush="{DynamicResource FilterPopupBorder}"
             BorderThickness="1"
             Padding="5"
             Width="220"
             MaxHeight="{DynamicResource FilterPopupMaxHeight}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVis"
                                              Invert="True" />
        <BooleanToVisibilityConverter x:Key="SystemBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sort Buttons -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,5">
            <Button Content="Sort A to Z"
                    Command="{Binding SortAscendingCommand}"
                    Margin="0,2" />
            <Button Content="Sort Z to A"
                    Command="{Binding SortDescendingCommand}"
                    Margin="0,2" />
            <Button Content="Add Sort A to Z"
                    Command="{Binding AddSubSortAscendingCommand}"
                    Margin="0,2" />
            <Button Content="Add Sort Z to A"
                    Command="{Binding AddSubSortDescendingCommand}"
                    Margin="0,2" />
            <Separator Margin="0,5" />
        </StackPanel>

        <!-- Search Box -->
        <StackPanel Grid.Row="1" Margin="0,0,0,5">
            <TextBox Padding="2"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                <i:Interaction.Behaviors>
                    <!-- Using attached behavior for async debounce (if wired to command) -->
                    <!-- <behaviors:AsyncFilterBehavior Delay="0:0:0.3"/> -->
                </i:Interaction.Behaviors>
            </TextBox>
            <CheckBox Content="Add current selection to filter"
                      IsChecked="{Binding AddToExistingFilter}"
                      Margin="0,5,0,0"
                      FontSize="11" />
        </StackPanel>

        <!-- Custom Filter -->
        <Expander Grid.Row="2"
                  Header="Advanced Filter"
                  IsExpanded="{Binding IsCustomFilterExpanded}"
                  Margin="0,0,0,5"
                  Padding="2">
            <StackPanel Margin="5">
                <TextBlock Text="Operator:" FontSize="10" Foreground="Gray"/>
                <ComboBox ItemsSource="{Binding AvailableOperators}"
                          SelectedItem="{Binding SelectedCustomOperator}"
                          Margin="0,2,0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Value:" FontSize="10" Foreground="Gray"/>
                <TextBox Text="{Binding CustomValue1, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,2"/>

                <StackPanel Visibility="{Binding SelectedCustomOperator, Converter={StaticResource BoolToVis}, ConverterParameter=Between}">
                    <TextBlock Text="To:" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding CustomValue2, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2"/>
                </StackPanel>
            </StackPanel>
        </Expander>

        <!-- Loading Indicator -->
        <TextBlock Grid.Row="3"
                   Text="Loading..."
                   HorizontalAlignment="Center"
                   Margin="0,5"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Filter List -->
        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource InvertedBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FilterValues.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <CheckBox Grid.Row="0"
                      Content="(Select All)"
                      Margin="2"
                      IsChecked="{Binding SelectAll}"
                      IsThreeState="True"
                      Style="{DynamicResource FilterCheckBoxStyle}" />
            <Separator Grid.Row="1" Margin="0,5" />
            
            <TreeView Grid.Row="2"
                      ItemsSource="{Binding FilterValues}" 
                      BorderThickness="0" 
                      Background="Transparent"
                      Padding="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="False" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <CheckBox Content="{Binding DisplayText}"
                                  IsChecked="{Binding IsSelected}"
                                  IsThreeState="True"
                                  Margin="2"
                                  Style="{DynamicResource FilterCheckBoxStyle}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="4"
              Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="OK"
                    Command="{Binding ApplyCommand}"
                    Style="{DynamicResource FilterButtonStyle}" />
            <Button Grid.Column="2"
                    Content="Clear"
                    Command="{Binding ClearCommand}"
                    Style="{DynamicResource FilterButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
