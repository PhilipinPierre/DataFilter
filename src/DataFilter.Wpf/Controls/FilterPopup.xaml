<UserControl x:Class="DataFilter.Wpf.Controls.FilterPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:DataFilter.Wpf.Converters"
             xmlns:behaviors="clr-namespace:DataFilter.Wpf.Behaviors"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:loc="clr-namespace:DataFilter.Localization;assembly=DataFilter.Localization"
             xmlns:core="clr-namespace:DataFilter.Core.Enums;assembly=DataFilter.Core"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewmodels:ColumnFilterViewModel}"
             Background="{DynamicResource FilterPopupBackground}"
             Foreground="{DynamicResource FilterPopupForeground}"
             BorderBrush="{DynamicResource FilterPopupBorder}"
             BorderThickness="1"
             Padding="5"
             Width="220"
             MaxHeight="{DynamicResource FilterPopupMaxHeight}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVis"
                                              Invert="True" />
        <BooleanToVisibilityConverter x:Key="SystemBoolToVis" />
        <converters:OperatorToLocalizedDescriptionConverter x:Key="OperatorConverter" />
        <converters:AccumulationModeToLocalizedDescriptionConverter x:Key="ModeConverter" />
        <ObjectDataProvider x:Key="AccumulationModeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type core:AccumulationMode}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:AccumulationMode" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sort Buttons -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,5">
            <Button Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SortAscending]}"
                    AutomationProperties.AutomationId="df-sort-asc"
                    Command="{Binding SortAscendingCommand}"
                    Margin="0,2" />
            <Button Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SortDescending]}"
                    AutomationProperties.AutomationId="df-sort-desc"
                    Command="{Binding SortDescendingCommand}"
                    Margin="0,2" />
            <Button Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AddSubSortAscending]}"
                    AutomationProperties.AutomationId="df-add-subsort-asc"
                    Command="{Binding AddSubSortAscendingCommand}"
                    Margin="0,2" />
            <Button Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AddSubSortDescending]}"
                    AutomationProperties.AutomationId="df-add-subsort-desc"
                    Command="{Binding AddSubSortDescendingCommand}"
                    Margin="0,2" />
            <Separator Margin="0,5" />
        </StackPanel>

        <!-- Search Box -->
        <StackPanel Grid.Row="1" Margin="0,0,0,5">
            <TextBox Padding="2"
                     AutomationProperties.AutomationId="df-search"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                <i:Interaction.Behaviors>
                    <!-- Using attached behavior for async debounce (if wired to command) -->
                    <!-- <behaviors:AsyncFilterBehavior Delay="0:0:0.3"/> -->
                </i:Interaction.Behaviors>
            </TextBox>
            <StackPanel Margin="0,5,0,0">
                <CheckBox Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AddToFilter]}"
                          AutomationProperties.AutomationId="df-add-to-existing"
                          IsChecked="{Binding AddToExistingFilter}"
                          VerticalAlignment="Center"
                          FontSize="11" />
                <ComboBox ItemsSource="{Binding Source={StaticResource AccumulationModeValues}}"
                          AutomationProperties.AutomationId="df-accumulation-mode"
                          SelectedItem="{Binding AccumulationMode}"
                          Visibility="{Binding AddToExistingFilter, Converter={StaticResource BoolToVis}}"
                          Margin="10,0,0,0"
                          VerticalAlignment="Center"
                          FontSize="10"
                          Height="20">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource ModeConverter}">
                                        <Binding />
                                        <Binding Source="{x:Static loc:LocalizationManager.Instance}" Path="Version" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Custom Filter -->
        <Expander Grid.Row="2"
                  AutomationProperties.AutomationId="df-advanced-expander"
                  Header="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[AdvancedFilter]}"
                  IsExpanded="{Binding IsCustomFilterExpanded}"
                  Margin="0,0,0,5"
                  Padding="2">
            <StackPanel Margin="5">
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[OperatorText]}" FontSize="10" Foreground="Gray"/>
                <ComboBox ItemsSource="{Binding AvailableOperators}"
                          AutomationProperties.AutomationId="df-operator"
                          SelectedItem="{Binding SelectedCustomOperator}"
                          Margin="0,2,0,5">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource OperatorConverter}">
                                        <Binding />
                                        <Binding Source="{x:Static loc:LocalizationManager.Instance}" Path="Version" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ValueText]}" FontSize="10" Foreground="Gray"/>
                <TextBox Text="{Binding CustomValue1, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.AutomationId="df-custom-value-1"
                         Margin="0,2"/>

                <StackPanel Visibility="{Binding SelectedCustomOperator, Converter={StaticResource BoolToVis}, ConverterParameter=Between}">
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[ToText]}" FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                    <TextBox Text="{Binding CustomValue2, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="df-custom-value-2"
                             Margin="0,2"/>
                </StackPanel>
            </StackPanel>
        </Expander>

        <!-- Loading Indicator -->
        <TextBlock Grid.Row="3"
                   Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[LoadingText]}"
                   HorizontalAlignment="Center"
                   Margin="0,5"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

        <!-- Filter List -->
        <Grid Grid.Row="3" Visibility="{Binding IsLoading, Converter={StaticResource InvertedBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FilterValues.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <CheckBox Grid.Row="0"
                      Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[SelectAll]}"
                      AutomationProperties.AutomationId="df-select-all"
                      Margin="2"
                      IsChecked="{Binding SelectAll}"
                      IsThreeState="True"
                      Style="{DynamicResource FilterCheckBoxStyle}" />
            <Separator Grid.Row="1" Margin="0,5" />
            
            <TreeView Grid.Row="2"
                      AutomationProperties.AutomationId="df-values-tree"
                      ItemsSource="{Binding FilterValues}" 
                      BorderThickness="0" 
                      Background="Transparent"
                      Padding="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      VirtualizingStackPanel.IsVirtualizing="True">
                <TreeView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </TreeView.ItemsPanel>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="False" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <CheckBox Content="{Binding DisplayText}"
                                  IsChecked="{Binding IsSelected}"
                                  IsThreeState="True"
                                  Margin="2"
                                  Style="{DynamicResource FilterCheckBoxStyle}" />
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="4"
              Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Ok]}"
                    AutomationProperties.AutomationId="df-ok"
                    Command="{Binding ApplyCommand}"
                    Style="{DynamicResource FilterButtonStyle}" />
            <Button Grid.Column="2"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Clear]}"
                    AutomationProperties.AutomationId="df-clear"
                    Command="{Binding ClearCommand}"
                    Style="{DynamicResource FilterButtonStyle}" />
        </Grid>

        <!-- Resize Handle -->
        <Thumb Grid.Row="4" 
               AutomationProperties.AutomationId="df-resize-thumb"
               HorizontalAlignment="Right" 
               VerticalAlignment="Bottom" 
               Width="15" 
               Height="15" 
               Cursor="SizeNWSE"
               DragDelta="OnResizeThumbDragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Path Data="M 12,0 L 15,0 L 15,15 L 0,15 L 0,12 L 12,12 Z" 
                              Fill="Gray" 
                              Opacity="0.5" 
                              Margin="0,0,2,2" />
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</UserControl>
