<UserControl x:Class="DataFilter.Wpf.Controls.FilterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fb="clr-namespace:DataFilter.PlatformShared.FilterBar;assembly=DataFilter.PlatformShared"
             xmlns:loc="clr-namespace:DataFilter.Localization;assembly=DataFilter.Localization"
             x:Name="Root"
             AutomationProperties.AutomationId="df-filter-bar"
             Visibility="Collapsed">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type fb:FilterBarOrSeparatorItem}">
            <Border Margin="4,4,4,4"
                    Padding="8,4"
                    AllowDrop="True"
                    DragOver="OrGap_DragOver"
                    Drop="OrGap_Drop">
                <TextBlock Text="{Binding Text}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource FilterPopupForeground}" />
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ChipTemplate">
            <Border Margin="2"
                    Padding="6,3"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource FilterPopupBorder}"
                    Background="{DynamicResource FilterPopupBackground}"
                    PreviewMouseLeftButtonDown="Chip_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="Chip_PreviewMouseMove"
                    GiveFeedback="Chip_GiveFeedback">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding DisplayText}"
                            Command="{Binding DataContext.EditCommand, ElementName=Root}"
                            CommandParameter="{Binding NodeId}"
                            Tag="{Binding}"
                            PreviewMouseRightButtonUp="Chip_PreviewMouseRightButtonUp"
                            AutomationProperties.AutomationId="{Binding NodeId, StringFormat=df-filter-bar-chip-{0}}"
                            Padding="4,0"
                            Margin="0,0,2,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand" />
                    <Button Content="×"
                            Command="{Binding DataContext.RemoveCommand, ElementName=Root}"
                            CommandParameter="{Binding NodeId}"
                            Width="22"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type fb:FilterBarAndClusterItem}">
            <Border Margin="2,4"
                    Padding="6,4"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource FilterPopupBorder}"
                    Background="#08000000"
                    AllowDrop="True"
                    DragOver="Cluster_DragOver"
                    Drop="Cluster_Drop"
                    AutomationProperties.AutomationId="{Binding GroupNodeId, StringFormat=df-filter-bar-group-{0}}">
                <WrapPanel Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding Chips}"
                                  ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </WrapPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  Padding="4">
        <StackPanel Orientation="Horizontal">
            <Button Content="OR+"
                    Command="{Binding AddOrGroupCommand}"
                    ToolTip="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[FilterBar_AddOrGroup]}"
                    AutomationProperties.AutomationId="df-filter-bar-add-or-group"
                    Margin="2,4,8,4"
                    Padding="8,2"
                    VerticalAlignment="Center" />
            <ItemsControl ItemsSource="{Binding Segments}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
