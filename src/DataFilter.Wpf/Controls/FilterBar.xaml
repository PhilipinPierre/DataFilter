<UserControl x:Class="DataFilter.Wpf.Controls.FilterBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fb="clr-namespace:DataFilter.PlatformShared.FilterBar;assembly=DataFilter.PlatformShared"
             xmlns:converters="clr-namespace:DataFilter.Wpf.Converters"
             x:Name="Root"
             AutomationProperties.AutomationId="df-filter-bar"
             Visibility="Collapsed">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <DataTemplate DataType="{x:Type fb:FilterBarOrSeparatorItem}">
            <TextBlock Text="{Binding Text}"
                       VerticalAlignment="Center"
                       Margin="12,4,4,4"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource FilterPopupForeground}" />
        </DataTemplate>

        <DataTemplate x:Key="ChipTemplate">
            <Border Margin="2"
                    Padding="6,3"
                    CornerRadius="4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource FilterPopupBorder}"
                    Background="{DynamicResource FilterPopupBackground}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <Button Content="{Binding DisplayText}"
                            Command="{Binding DataContext.EditCommand, ElementName=Root}"
                            CommandParameter="{Binding NodeId}"
                            Tag="{Binding}"
                            PreviewMouseRightButtonUp="Chip_PreviewMouseRightButtonUp"
                            AutomationProperties.AutomationId="{Binding NodeId, StringFormat=df-filter-bar-chip-{0}}"
                            Padding="4,0"
                            Margin="0,0,2,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand" />
                    <Button Content="+"
                            Command="{Binding DataContext.AddAndCommand, ElementName=Root}"
                            CommandParameter="{Binding NodeId}"
                            AutomationProperties.AutomationId="{Binding NodeId, StringFormat=df-filter-bar-add-{0}}"
                            Width="22"
                            Visibility="{Binding CanAddAnd, Converter={StaticResource BoolToVis}}" />
                    <Button Content="×"
                            Command="{Binding DataContext.RemoveCommand, ElementName=Root}"
                            CommandParameter="{Binding NodeId}"
                            Width="22"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type fb:FilterBarAndClusterItem}">
            <Border Margin="2,4"
                    Padding="6,4"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource FilterPopupBorder}"
                    Background="#08000000"
                    AutomationProperties.AutomationId="{Binding GroupNodeId, StringFormat=df-filter-bar-group-{0}}">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="+"
                            Command="{Binding DataContext.AddAndCommand, ElementName=Root}"
                            CommandParameter="{Binding AddAndAnchorNodeId}"
                            AutomationProperties.AutomationId="{Binding AddAndAnchorNodeId, StringFormat=df-filter-bar-group-add-{0}}"
                            Width="24"
                            Margin="0,0,6,0"
                            Visibility="{Binding CanAddAnd, Converter={StaticResource BoolToVis}}" />
                    <ItemsControl ItemsSource="{Binding Chips}"
                                  ItemTemplate="{StaticResource ChipTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </WrapPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  Padding="4">
        <ItemsControl ItemsSource="{Binding Segments}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
