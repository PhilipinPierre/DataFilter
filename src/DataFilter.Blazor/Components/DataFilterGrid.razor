@typeparam TItem
@using DataFilter.Blazor.ViewModels
@using DataFilter.Filtering.ExcelLike.Models
@using DataFilter.Core.Enums
@using DataFilter.Core.Abstractions
@using DataFilter.Core.Models
@using System.Linq

<div class="df-grid-container">
    <table class="df-grid">
        <thead>
            <tr>
                @foreach (var col in Columns)
                {
                    <th class="df-grid-header">
                        <div class="df-header-content">
                            <span>@col.Title</span>
                            <ColumnFilterButton ViewModel="@GetViewModel(col)" />
                        </div>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @if (_isLoading)
            {
                <tr>
                    <td colspan="@Columns.Count" class="text-center p-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in _filteredItems)
                {
                    <tr>
                        @foreach (var col in Columns)
                        {
                            <td>@col.Selector(item)</td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public IAsyncDataProvider<TItem>? DataProvider { get; set; }
    [Parameter] public List<ColumnDefinition<TItem>> Columns { get; set; } = new();
    [Parameter] public int PageSize { get; set; } = 20;

    private Dictionary<string, IBlazorColumnFilterViewModel> _viewModels = new();
    private List<TItem> _filteredItems = new();
    private readonly List<(string PropertyName, bool IsDescending)> _sortDescriptors = new();
    private bool _isLoading;
    private int _currentPage = 1;

    protected override async Task OnParametersSetAsync()
    {
        await ApplyFiltersAsync();
    }

    private async Task ApplyFiltersAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var descriptors = new List<IFilterDescriptor>();
            foreach (var entry in _viewModels)
            {
                var vm = entry.Value;
                var column = Columns.FirstOrDefault(c => c.Id == entry.Key);
                if (column == null || string.IsNullOrEmpty(column.PropertyName)) continue;

                if (vm.IsFilterActive)
                {
                    var group = new FilterGroup(LogicalOperator.And);
                    
                    // Selections
                    if (!vm.FilterState.SelectAll && vm.FilterState.SelectedValues.Count > 0)
                    {
                        group.Add(new FilterDescriptor(column.PropertyName, FilterOperator.In, vm.FilterState.SelectedValues.ToList()));
                    }
                    
                    // Custom Filter
                    if (vm.FilterState.CustomOperator.HasValue)
                    {
                        object? val = vm.FilterState.CustomValue1;
                        if (vm.FilterState.CustomOperator == FilterOperator.Between)
                        {
                            val = new RangeValue(vm.FilterState.CustomValue1, vm.FilterState.CustomValue2);
                        }
                        group.Add(new FilterDescriptor(column.PropertyName, vm.FilterState.CustomOperator.Value, val));
                    }

                    if (group.Descriptors.Count > 0)
                    {
                        descriptors.Add(group);
                    }
                }
            }

            if (DataProvider != null)
            {
                var context = new FilterContext
                {
                    // Descriptors = descriptors,
                    // SortDescriptors = _sortDescriptors.Select(s => new DataFilter.Core.Models.SortDescriptor(s.PropertyName, s.IsDescending)).Cast<ISortDescriptor>().ToList(),
                    Page = _currentPage,
                    PageSize = PageSize
                };

                var result = await DataProvider.FetchDataAsync(context);
                _filteredItems = result.Items.ToList();
            }
            else
            {
                IEnumerable<TItem> results;
                if (descriptors.Count > 0)
                {
                    var engine = new DataFilter.Core.Engine.ReflectionFilterEngine<TItem>();
                    results = engine.Apply(Items, descriptors);
                }
                else
                {
                    results = Items;
                }

                // Apply sorting after filtering (if any)
                if (_sortDescriptors.Count > 0)
                {
                    var flags = System.Reflection.BindingFlags.IgnoreCase | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance;
                    IOrderedEnumerable<TItem>? ordered = null;

                    foreach (var sort in _sortDescriptors)
                    {
                        var propInfo = typeof(TItem).GetProperty(sort.PropertyName, flags);
                        if (propInfo == null) continue;

                        if (ordered == null)
                        {
                            ordered = sort.IsDescending
                                ? results.OrderByDescending(x => propInfo.GetValue(x))
                                : results.OrderBy(x => propInfo.GetValue(x));
                        }
                        else
                        {
                            ordered = sort.IsDescending
                                ? ordered.ThenByDescending(x => propInfo.GetValue(x))
                                : ordered.ThenBy(x => propInfo.GetValue(x));
                        }
                    }

                    _filteredItems = ordered?.ToList() ?? results.ToList();
                }
                else
                {
                    _filteredItems = results.ToList();
                }
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private IBlazorColumnFilterViewModel GetViewModel(ColumnDefinition<TItem> column)
    {
        if (!_viewModels.TryGetValue(column.Id, out var vm))
        {
            vm = new BlazorColumnFilterViewModel(
                async (search) => {
                    if (DataProvider != null)
                    {
                        return await DataProvider.FetchDistinctValuesAsync(column.PropertyName, search);
                    }
                    var distinctValues = Items.Select(column.Selector).Distinct();
                    if (!string.IsNullOrEmpty(search))
                    {
                         distinctValues = distinctValues.Where(x => x?.ToString()?.Contains(search, StringComparison.OrdinalIgnoreCase) == true);
                    }
                    return distinctValues.ToList();
                },
                async (state) => { 
                    await ApplyFiltersAsync();
                },
                async () => { 
                    await ApplyFiltersAsync();
                },
                async (isDescending) =>
                {
                    SetSortInternal(column.PropertyName, isDescending);
                    await ApplyFiltersAsync();
                },
                async (isDescending) =>
                {
                    AddSubSortInternal(column.PropertyName, isDescending);
                    await ApplyFiltersAsync();
                },
                column.PropertyType
            );
            
            // Initialize VM with distinct values
            if (DataProvider == null)
            {
                _ = vm.InitializeAsync(Items.Select(column.Selector).Distinct());
            }
            else
            {
                // For async, we let the VM fetch values when popup opens, or we can pre-fetch
                // vm.InitializeAsync will be called by the popup if needed
            }
            
            _viewModels[column.Id] = vm;
        }
        return vm;
    }

    public async Task ClearFilters()
    {
        foreach (var vm in _viewModels.Values)
        {
            vm.ClearFilter();
        }
        await ApplyFiltersAsync();
    }

    private void SetSortInternal(string propertyName, bool isDescending)
    {
        if (string.IsNullOrWhiteSpace(propertyName)) return;
        _sortDescriptors.Clear();
        _sortDescriptors.Add((propertyName, isDescending));
    }

    private void AddSubSortInternal(string propertyName, bool isDescending)
    {
        if (string.IsNullOrWhiteSpace(propertyName)) return;
        _sortDescriptors.RemoveAll(s => string.Equals(s.PropertyName, propertyName, StringComparison.OrdinalIgnoreCase));
        _sortDescriptors.Add((propertyName, isDescending));
    }

    public class ColumnDefinition<T>
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string PropertyName { get; set; } = "";
        public Func<T, object> Selector { get; set; } = default!;
        public Type PropertyType { get; set; } = typeof(string);
    }
}
