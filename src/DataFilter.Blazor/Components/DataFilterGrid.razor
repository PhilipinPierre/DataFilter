@typeparam TItem
@using DataFilter.PlatformShared.ViewModels
@using DataFilter.PlatformShared.ColumnFilter
@using DataFilter.PlatformShared.Theming
@using DataFilter.Filtering.ExcelLike.Models
@using DataFilter.Filtering.ExcelLike.Services
@using DataFilter.Core.Enums
@using DataFilter.Core.Abstractions
@using DataFilter.Core.Models
@using DataFilter.Core.Pipeline
@using DataFilter.Core.Services
@using DataFilter.PlatformShared.FilterBar
@using DataFilter.PlatformShared.Pipeline
@using System.Linq

@if (Headless && ChildContent != null)
{
    @ChildContent(GridContext)
}
else
{
    <div class="df-grid-container @ThemeClass" style="@GetThemeStyle()">
        @if (ShowFilterBar)
        {
            <FilterBar ViewModel="_filterBar" OnEdit="HandleBarEditAsync" />
        }
        @if (_barEditColumn is not null && _barPopupVisible)
        {
            <div class="df-bar-edit-popup">
                <FilterPopup ViewModel="@GetViewModel(_barEditColumn)"
                             Visible="true"
                             VisibleChanged="OnBarPopupVisibleChanged"
                             ElementId="@($"df-filter-popup-bar-{_barEditColumn.PropertyName}")" />
            </div>
        }
        <table class="df-grid">
            <thead>
                <tr>
                    @foreach (var col in Columns)
                    {
                        <th class="@GetHeaderChromeClass(col)">
                            <div class="df-header-content">
                                @{
                                    var triggerMode = GetEffectiveTriggerMode(col);
                                }
                                @if (!ColumnFilterHeaderOptions.HasHeaderFilterTrigger(triggerMode) || ColumnFilterHeaderOptions.UsesAlwaysVisibleFilterButton(triggerMode))
                                {
                                    <span>@col.Title</span>
                                }
                                @if (ColumnFilterHeaderOptions.HasHeaderFilterTrigger(triggerMode))
                                {
                                    <ColumnFilterButton ViewModel="@GetViewModel(col)"
                                                        ColumnKey="@col.PropertyName"
                                                        Title="@(ColumnFilterHeaderOptions.UsesAlwaysVisibleFilterButton(triggerMode) ? null : col.Title)"
                                                        AreColumnFiltersEnabled="@AreColumnFiltersEnabled"
                                                        IsFilterable="@col.IsFilterable"
                                                        TriggerMode="@triggerMode">
                                        <PopupContent Context="popup">
                                            <FilterPopup ViewModel="@GetViewModel(col)"
                                                         Visible="popup.Visible"
                                                         VisibleChanged="popup.VisibleChanged"
                                                         ElementId="@popup.PopupElementId"
                                                         PopupStyle="@popup.PopupStyle" />
                                        </PopupContent>
                                    </ColumnFilterButton>
                                }
                            </div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (_isLoading)
                {
                    <tr>
                        <td colspan="@Columns.Count" class="text-center p-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in _filteredItems)
                    {
                        <tr>
                            @foreach (var col in Columns)
                            {
                                <td>@col.Selector(item)</td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public IEnumerable<TItem> Items { get; set; } = Enumerable.Empty<TItem>();
    [Parameter] public IAsyncDataProvider<TItem>? DataProvider { get; set; }
    [Parameter] public List<ColumnDefinition<TItem>> Columns { get; set; } = new();
    [Parameter] public int PageSize { get; set; } = 20;
    [Parameter] public bool Headless { get; set; }
    [Parameter] public bool ShowFilterBar { get; set; }
    [Parameter] public bool AreColumnFiltersEnabled { get; set; } = true;
    [Parameter] public ColumnFilterTriggerMode ColumnFilterTriggerMode { get; set; } = ColumnFilterTriggerMode.FilterButton;
    /// <summary>CSS class for theme scope (e.g. <see cref="FilterThemeResourceKeys.BlazorDarkThemeClass"/>).</summary>
    [Parameter] public string ThemeClass { get; set; } = "";
    /// <summary>When set, emits inline CSS custom properties from <see cref="FilterTheme.ToCssVariables"/>.</summary>
    [Parameter] public FilterTheme? Theme { get; set; }
    [Parameter] public RenderFragment<DataFilterGridContext<TItem>>? ChildContent { get; set; }

    private readonly FilterPipelineSession _pipelineSession = new();
    private FilterBarViewModel _filterBar = null!;
    private ColumnDefinition<TItem>? _barEditColumn;
    private bool _barPopupVisible;
    private Dictionary<string, IColumnFilterViewModel> _viewModels = new();
    private List<TItem> _filteredItems = new();
    private readonly List<(string PropertyName, bool IsDescending)> _sortDescriptors = new();
    private bool _isLoading;
    private int _currentPage = 1;
    private readonly FilterContext _context = new();
    private IEnumerable<TItem>? _itemsSourceReference;
    private static readonly DistinctValuesExtractor DistinctExtractor = new();

    private DataFilterGridContext<TItem> GridContext => new(
        getColumnFilterViewModel: id =>
        {
            var col = Columns.FirstOrDefault(c => string.Equals(c.Id, id, StringComparison.Ordinal));
            if (col == null) throw new InvalidOperationException($"Unknown column id '{id}'.");
            return GetViewModel(col);
        },
        getFilteredItems: () => _filteredItems,
        getIsLoading: () => _isLoading,
        areColumnFiltersEnabled: AreColumnFiltersEnabled,
        columnFilterTriggerMode: ColumnFilterTriggerMode,
        isColumnFilterEnabled: IsColumnFilterEnabled,
        getEffectiveTriggerMode: GetEffectiveTriggerMode);

    protected override void OnInitialized()
    {
        _filterBar = new FilterBarViewModel(_pipelineSession);
        _filterBar.Configure(ResolveColumnTitle, ApplyFilterPipelineAsync, ResolveDefaultFilterBarPropertyName);
    }

    private string? ResolveDefaultFilterBarPropertyName() =>
        Columns.FirstOrDefault(c => !string.IsNullOrWhiteSpace(c.PropertyName))?.PropertyName;

    protected override async Task OnParametersSetAsync()
    {
        var itemsSourceChanged = !ReferenceEquals(_itemsSourceReference, Items);
        _itemsSourceReference = Items;

        // Re-applying from column VMs on every parent re-render would wipe JSON/pipeline presets.
        if (itemsSourceChanged || _filteredItems.Count == 0)
            await ApplyFiltersAsync();
    }

    private bool IsColumnFilterEnabled(ColumnDefinition<TItem> column) =>
        ColumnFilterHeaderOptions.IsFilteringEnabled(AreColumnFiltersEnabled, column.IsFilterable);

    private ColumnFilterTriggerMode GetEffectiveTriggerMode(ColumnDefinition<TItem> column) =>
        ColumnFilterHeaderOptions.ResolveTriggerMode(ColumnFilterTriggerMode, column.TriggerMode);

    private string GetHeaderChromeClass(ColumnDefinition<TItem> column)
    {
        if (!IsColumnFilterEnabled(column))
            return "df-grid-header";

        var mode = GetEffectiveTriggerMode(column);
        if (!ColumnFilterHeaderOptions.ShowsFilterStateOnHeaderBorder(mode))
            return "df-grid-header";

        return GetViewModel(column).IsFilterActive
            ? $"df-grid-header {ColumnFilterHeaderChrome.BlazorFilteredIndicatorClass}"
            : "df-grid-header";
    }

    private string ResolveColumnTitle(string propertyName) =>
        Columns.FirstOrDefault(c => string.Equals(c.PropertyName, propertyName, StringComparison.OrdinalIgnoreCase))?.Title
        ?? propertyName;

    private async Task ApplyFiltersAsync()
    {
        await ApplyFiltersCoreAsync(CollectActiveDescriptorsFromViewModels());
        SyncFilterBarFromContext();
    }

    private void SyncFilterBarFromContext()
    {
        _pipelineSession.SyncFromContext(_context);
        _filterBar.RebuildDisplay();
    }

    private List<IFilterDescriptor> CollectActiveDescriptorsFromViewModels()
    {
        var descriptors = new List<IFilterDescriptor>();
        foreach (var entry in _viewModels)
        {
            var vm = entry.Value;
            var column = Columns.FirstOrDefault(c => c.Id == entry.Key);
            if (column == null || string.IsNullOrEmpty(column.PropertyName))
                continue;

            if (vm.IsFilterActive)
                descriptors.Add(new ExcelFilterDescriptor(column.PropertyName, vm.FilterState));
        }

        return descriptors;
    }

    private async Task ApplyFiltersCoreAsync(IReadOnlyList<IFilterDescriptor> descriptors)
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _context.ReplaceDescriptors(descriptors);
            _context.ClearSort();
            foreach (var s in _sortDescriptors)
                _context.AddSort(s.PropertyName, s.IsDescending);
            _context.Page = _currentPage;
            _context.PageSize = PageSize;

            if (DataProvider != null)
            {
                var result = await DataProvider.FetchDataAsync(_context);
                _filteredItems = result.Items.ToList();
            }
            else
            {
                IEnumerable<TItem> results;
                if (descriptors.Count > 0)
                {
                    var engine = new DataFilter.Core.Engine.ReflectionFilterEngine<TItem>();
                    results = engine.Apply(Items, descriptors);
                }
                else
                {
                    results = Items;
                }

                if (_sortDescriptors.Count > 0)
                {
                    var flags = System.Reflection.BindingFlags.IgnoreCase | System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance;
                    IOrderedEnumerable<TItem>? ordered = null;

                    foreach (var sort in _sortDescriptors)
                    {
                        var propInfo = typeof(TItem).GetProperty(sort.PropertyName, flags);
                        if (propInfo == null) continue;

                        if (ordered == null)
                        {
                            ordered = sort.IsDescending
                                ? results.OrderByDescending(x => propInfo.GetValue(x))
                                : results.OrderBy(x => propInfo.GetValue(x));
                        }
                        else
                        {
                            ordered = sort.IsDescending
                                ? ordered.ThenByDescending(x => propInfo.GetValue(x))
                                : ordered.ThenBy(x => propInfo.GetValue(x));
                        }
                    }

                    _filteredItems = ordered?.ToList() ?? results.ToList();
                }
                else
                {
                    _filteredItems = results.ToList();
                }
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private IColumnFilterViewModel GetViewModel(ColumnDefinition<TItem> column)
    {
        if (!_viewModels.TryGetValue(column.Id, out var vm))
        {
            vm = new ColumnFilterViewModel(
                async (search) =>
                {
                    if (DataProvider != null)
                    {
                        return await DataProvider.FetchDistinctValuesAsync(column.PropertyName, search);
                    }

                    return GetLocalDistinctValues(column, search);
                },
                _state => { _ = ApplyFiltersAsync(); },
                () => { _ = ApplyFiltersAsync(); },
                isDescending =>
                {
                    SetSortInternal(column.PropertyName, isDescending);
                    _ = ApplyFiltersAsync();
                },
                isDescending =>
                {
                    AddSubSortInternal(column.PropertyName, isDescending);
                    _ = ApplyFiltersAsync();
                },
                column.PropertyType
            );
            
            // Initialize VM with distinct values
            if (DataProvider == null)
            {
                _ = vm.InitializeAsync(GetLocalDistinctValues(column, string.Empty));
            }
            else
            {
                // For async, we let the VM fetch values when popup opens, or we can pre-fetch
                // vm.InitializeAsync will be called by the popup if needed
            }
            
            _viewModels[column.Id] = vm;
        }
        return vm;
    }

    private IEnumerable<object> GetLocalDistinctValues(ColumnDefinition<TItem> column, string search)
    {
        IEnumerable<object> distinctValues = !string.IsNullOrWhiteSpace(column.PropertyName)
            ? DistinctExtractor.Extract(Items, typeof(TItem), column.PropertyName)
            : Items.Select(column.Selector).Distinct().Cast<object>();

        if (!string.IsNullOrEmpty(search))
        {
            distinctValues = distinctValues.Where(x =>
                x?.ToString()?.Contains(search, StringComparison.OrdinalIgnoreCase) == true);
        }

        return distinctValues.ToList();
    }

    public async Task ClearFilters()
    {
        foreach (var vm in _viewModels.Values)
        {
            vm.ClearFilter();
        }
        await ApplyFiltersAsync();
    }

    /// <summary>Live pipeline + sort session for direct client edits (no JSON).</summary>
    public FilterPipelineSession PipelineSession => _pipelineSession;

    public FilterPipelineSnapshot CreatePipelineSnapshotFromCurrentGrid()
        => CreateFilterPipelineSnapshot();

    /// <summary>Clones the current grid state as a mutable snapshot.</summary>
    public FilterPipelineSnapshot CreateFilterPipelineSnapshot()
    {
        SyncSessionSortFromGrid();
        _pipelineSession.SyncFromContext(_context);
        return FilterPipelineSnapshotEditor.Clone(_pipelineSession.ToSnapshot());
    }

    public async Task ApplyPipelineSnapshotAsync(FilterPipelineSnapshot snapshot)
        => await ApplyFilterPipelineSnapshotAsync(snapshot);

    public async Task ApplyFilterPipelineSnapshotAsync(FilterPipelineSnapshot snapshot)
    {
        if (snapshot == null) throw new ArgumentNullException(nameof(snapshot));

        _pipelineSession.ReplaceFromSnapshot(snapshot);
        await ApplyFilterPipelineCoreAsync(_pipelineSession.Pipeline, replaceSort: true);
    }

    public async Task ApplyFilterPipelineAsync(FilterPipeline pipeline)
    {
        if (pipeline == null) throw new ArgumentNullException(nameof(pipeline));

        _pipelineSession.ReplacePipeline(pipeline);
        await ApplyFilterPipelineCoreAsync(pipeline, replaceSort: false);
    }

    /// <summary>Applies <see cref="PipelineSession"/> after in-memory edits to pipeline or sort lists.</summary>
    public async Task ApplyPipelineSessionAsync()
    {
        await ApplyFilterPipelineCoreAsync(_pipelineSession.Pipeline, replaceSort: true);
    }

    private async Task ApplyFilterPipelineCoreAsync(FilterPipeline pipeline, bool replaceSort)
    {
        var compiled = FilterPipelineCompiler.Compile(pipeline);
        var converted = FilterDescriptorToExcelConverter.ConvertCompiledPipeline(compiled);

        // Replace context so DataProvider / local engine run against the preset.
        _context.ReplaceDescriptors(converted);
        _context.Page = 1;
        FilterPipelineSnapshotMapper.ApplySortEntries(_context, _pipelineSession.SortEntries, replaceSort);
        if (replaceSort)
            SyncGridSortFromSession();

        // Best-effort sync back to per-column popups (works for descriptors that can be represented as ExcelFilterState).
        var byProperty = converted
            .OfType<ExcelFilterDescriptor>()
            .ToDictionary(d => d.PropertyName, d => d.State, StringComparer.OrdinalIgnoreCase);

        foreach (var col in Columns.Where(c => !string.IsNullOrWhiteSpace(c.PropertyName)))
        {
            var vm = GetViewModel(col);
            if (byProperty.TryGetValue(col.PropertyName, out var state))
            {
                await vm.LoadStateAsync(state);
            }
            else
            {
                vm.ClearFilter();
            }
        }

        await ApplyFiltersCoreAsync(converted);
        _filterBar.RebuildDisplay();
    }

    private async Task HandleBarEditAsync(FilterBarEditRequest request)
    {
        if (string.IsNullOrWhiteSpace(request.PropertyName))
            return;

        var col = Columns.FirstOrDefault(c =>
            string.Equals(c.PropertyName, request.PropertyName, StringComparison.OrdinalIgnoreCase));
        if (col == null)
            return;

        if (GetViewModel(col) is not ColumnFilterViewModel vm)
            return;

        vm.SetBarEditContext(new FilterBarEditContext
        {
            NodeId = request.NodeId,
            IsNew = request.IsNew,
            RemoveNodeOnClear = true,
            ApplyToPipelineAsync = state => ApplyBarCriterionAsync(request.NodeId, col.PropertyName, state),
            RemoveFromPipelineAsync = () => RemoveBarNodeAsync(request.NodeId)
        });

        if (_pipelineSession.TryGetNode(request.NodeId, out var node) && node is CriterionPipelineNode c)
        {
            ExcelFilterState? columnState = request.IsNew || !vm.IsFilterActive ? null : vm.FilterState;
            await vm.LoadFromCriterionAsync(c, columnState);
        }
        else
            await vm.SearchCommand.ExecuteAsync(string.Empty);

        _barEditColumn = col;
        _barPopupVisible = true;
        StateHasChanged();
    }

    private void OnBarPopupVisibleChanged(bool visible)
    {
        _barPopupVisible = visible;
        if (!visible)
        {
            if (GetViewModel(_barEditColumn!) is ColumnFilterViewModel barVm)
                barVm.SetBarEditContext(null);
            _barEditColumn = null;
        }
    }

    private async Task ApplyBarCriterionAsync(string nodeId, string propertyName, ExcelFilterState state)
    {
        if (_pipelineSession.TryGetNode(nodeId, out var node) && node is CriterionPipelineNode c)
            FilterBarCriterionMapper.ApplyStateToCriterion(c, propertyName, state);

        await ApplyPipelineSessionToContextAsync(replaceSort: false);
    }

    private async Task RemoveBarNodeAsync(string nodeId)
    {
        _pipelineSession.RemoveNode(nodeId);
        await ApplyPipelineSessionToContextAsync(replaceSort: false);
    }

    private async Task ApplyPipelineSessionToContextAsync(bool replaceSort)
    {
        var compiled = FilterPipelineCompiler.Compile(_pipelineSession.Pipeline);
        var converted = FilterDescriptorToExcelConverter.ConvertCompiledPipeline(compiled);
        _context.ReplaceDescriptors(converted);
        _context.Page = 1;
        FilterPipelineSnapshotMapper.ApplySortEntries(_context, _pipelineSession.SortEntries, replaceSort);
        if (replaceSort)
            SyncGridSortFromSession();

        var byProperty = converted
            .OfType<ExcelFilterDescriptor>()
            .ToDictionary(d => d.PropertyName, d => d.State, StringComparer.OrdinalIgnoreCase);

        foreach (var col in Columns.Where(c => !string.IsNullOrWhiteSpace(c.PropertyName)))
        {
            var colVm = GetViewModel(col);
            if (byProperty.TryGetValue(col.PropertyName, out var st))
                await colVm.LoadStateAsync(st);
            else
                colVm.ClearFilter();
        }

        await ApplyFiltersCoreAsync(converted);
        _filterBar.RebuildDisplay();
    }

    private void SetSortInternal(string propertyName, bool isDescending)
    {
        if (string.IsNullOrWhiteSpace(propertyName)) return;
        _sortDescriptors.Clear();
        _sortDescriptors.Add((propertyName, isDescending));
        SyncSessionSortFromGrid();
    }

    private void AddSubSortInternal(string propertyName, bool isDescending)
    {
        if (string.IsNullOrWhiteSpace(propertyName)) return;
        _sortDescriptors.RemoveAll(s => string.Equals(s.PropertyName, propertyName, StringComparison.OrdinalIgnoreCase));
        _sortDescriptors.Add((propertyName, isDescending));
        SyncSessionSortFromGrid();
    }

    private void SyncSessionSortFromGrid()
    {
        _pipelineSession.ReplaceSortEntries(_sortDescriptors.Select(s => new SortSnapshotEntry
        {
            PropertyName = s.PropertyName,
            IsDescending = s.IsDescending
        }));
    }

    private void SyncGridSortFromSession()
    {
        _sortDescriptors.Clear();
        foreach (SortSnapshotEntry sort in _pipelineSession.SortEntries)
            _sortDescriptors.Add((sort.PropertyName, sort.IsDescending));
    }

    private string GetThemeStyle() => Theme?.ToCssVariableStyle() ?? "";

    public class ColumnDefinition<T>
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string PropertyName { get; set; } = "";
        public Func<T, object> Selector { get; set; } = default!;
        public Type PropertyType { get; set; } = typeof(string);
        public bool IsFilterable { get; set; } = true;
        public ColumnFilterTriggerMode TriggerMode { get; set; } = ColumnFilterTriggerMode.Inherit;
    }
}
