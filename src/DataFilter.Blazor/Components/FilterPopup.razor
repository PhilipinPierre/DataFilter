@using DataFilter.PlatformShared.ViewModels
@using DataFilter.Core.Enums
@using DataFilter.Filtering.ExcelLike.Models
@using System.ComponentModel
@using Microsoft.JSInterop
@using DataFilter.Localization
@implements IDisposable
@inject IJSRuntime JSRuntime

@if (Visible)
{
    <div id="@ElementId" class="df-popup-container" style="@PopupStyle">
        <div class="df-popup-body">
            <!-- Sort Buttons -->
            <div class="df-sort-section">
                <button class="df-sort-button" @onclick="() => ViewModel.SortAscendingCommand.Execute(null)">@LocalizationManager.Instance["SortAscending"]</button>
                <button class="df-sort-button" @onclick="() => ViewModel.SortDescendingCommand.Execute(null)">@LocalizationManager.Instance["SortDescending"]</button>
                <button class="df-sort-button" @onclick="() => ViewModel.AddSubSortAscendingCommand.Execute(null)">@LocalizationManager.Instance["AddSubSortAscending"]</button>
                <button class="df-sort-button" @onclick="() => ViewModel.AddSubSortDescendingCommand.Execute(null)">@LocalizationManager.Instance["AddSubSortDescending"]</button>
            </div>

            <hr />

            <!-- Search Box -->
            <div class="df-search-section">
                <input type="text" 
                       value="@ViewModel.SearchText" 
                       @oninput="OnSearchInput" 
                       class="df-search-input" 
                       placeholder="@LocalizationManager.Instance["SearchPlaceholder"]" />
                
                <div class="df-accumulation-options">
                    <label class="df-checkbox-label">
                        <input type="checkbox" @bind="ViewModel.AddToExistingFilter" />
                        @LocalizationManager.Instance["AddToFilter"]
                    </label>
                    
                    @if (ViewModel.AddToExistingFilter)
                    {
                        <select @bind="ViewModel.AccumulationMode" class="df-accumulation-select">
                            @foreach (var mode in Enum.GetValues<AccumulationMode>())
                            {
                                <option value="@mode">@GetAccumulationModeText(mode)</option>
                            }
                        </select>
                    }
                </div>
            </div>

            <!-- Custom Filter -->
            <div class="df-custom-filter-section">
                <div class="df-custom-filter-header" @onclick="ToggleCustomFilter">
                    <span>@LocalizationManager.Instance["AdvancedFilter"]</span>
                    <span>@(ViewModel.IsCustomFilterExpanded ? "▲" : "▼")</span>
                </div>
                @if (ViewModel.IsCustomFilterExpanded)
                {
                    <div class="df-custom-filter-body">
                        <select @bind="ViewModel.SelectedCustomOperator" class="df-custom-input">
                            <option value="">(None)</option>
                            @foreach (var op in ViewModel.AvailableOperators)
                            {
                                <option value="@op">@GetOperatorText(op)</option>
                            }
                        </select>

                        <input type="text" @bind="ViewModel.CustomValue1" class="df-custom-input" placeholder="@LocalizationManager.Instance["ValueText"]" />

                        @if (ViewModel.SelectedCustomOperator == FilterOperator.Between)
                        {
                            <input type="text" @bind="ViewModel.CustomValue2" class="df-custom-input" placeholder="@LocalizationManager.Instance["ToText"]" />
                        }
                    </div>
                }
            </div>

            <!-- Loading Indicator -->
            @if (ViewModel.IsLoading)
            {
                <div class="df-loading">@LocalizationManager.Instance["LoadingText"]</div>
            }

            <!-- Filter List -->
            <div class="df-value-list-section">
                <div class="df-value-item">
                    <input type="checkbox" 
                           checked="@ViewModel.SelectAll" 
                           indeterminate="@(ViewModel.SelectAll == null)"
                           @onchange="ToggleSelectAll" />
                    <span>@LocalizationManager.Instance["SelectAll"]</span>
                </div>
                
                @foreach (var item in ViewModel.FilterValues)
                {
                    <FilterValueItemView Item="item" Indent="0" />
                }
            </div>
        </div>

        <!-- Footer Buttons -->
        <div class="df-footer-buttons">
            <button class="df-btn-primary" @onclick="Apply">@LocalizationManager.Instance["Ok"]</button>
            <button class="df-btn-secondary" @onclick="Clear">@LocalizationManager.Instance["Clear"]</button>
        </div>

        <div id="@_resizeHandleId" class="df-resize-handle"></div>
    </div>
}

@code {
    [Parameter] public IColumnFilterViewModel ViewModel { get; set; } = default!;
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string PopupStyle { get; set; } = "";
    [Parameter] public string ElementId { get; set; } = "df-popup-" + Guid.NewGuid().ToString("N");

    private string _resizeHandleId = "resize-" + Guid.NewGuid().ToString("N");

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        LocalizationManager.Instance.CultureChanged += OnCultureChanged;
    }

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        LocalizationManager.Instance.CultureChanged -= OnCultureChanged;
    }

    private void OnCultureChanged(object? sender, EventArgs e) => InvokeAsync(StateHasChanged);

    private static string GetOperatorText(FilterOperator op)
        => LocalizationManager.Instance[$"FilterOperator_{op}"];

    private static string GetAccumulationModeText(AccumulationMode mode)
        => mode switch
        {
            AccumulationMode.Union => LocalizationManager.Instance["ModeUnion"],
            AccumulationMode.Intersection => LocalizationManager.Instance["ModeIntersection"],
            _ => mode.ToString()
        };

    private void OnViewModelPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async System.Threading.Tasks.Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible)
        {
            await JSRuntime.InvokeVoidAsync("DataFilterInterops.initResizable", ElementId, _resizeHandleId);
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        ViewModel.SearchText = e.Value?.ToString() ?? "";
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        ViewModel.SelectAll = (bool?)e.Value;
    }

    private void ToggleCustomFilter()
    {
        ViewModel.IsCustomFilterExpanded = !ViewModel.IsCustomFilterExpanded;
    }

    private void Apply()
    {
        ViewModel.ApplyCommand.Execute(null);
        Close();
    }

    private void Clear()
    {
        ViewModel.ClearCommand.Execute(null);
    }

    private void Close()
    {
        Visible = false;
        VisibleChanged.InvokeAsync(false);
    }

}
