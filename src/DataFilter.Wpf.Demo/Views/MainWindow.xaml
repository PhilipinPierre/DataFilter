<Window x:Class="DataFilter.Wpf.Demo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DataFilter.Wpf.Demo.Views"
        xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
        mc:Ignorable="d"
        Title="DataFilter WPF Demo"
        Height="600"
        Width="1000"
        d:DataContext="{d:DesignInstance Type={x:Type viewmodels:MainViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <TabControl Margin="10">
            <TabItem Header="Local Filtering">
                <views:LocalFilterView DataContext="{Binding CurrentScenario}" />
            </TabItem>
            <TabItem Header="Async Filtering">
                <views:AsyncFilterView DataContext="{Binding CurrentScenario}" />
            </TabItem>
            <!-- Other tabs follow same pattern -->
            <TabItem Header="Hybrid Filtering">
                <views:HybridFilterView DataContext="{Binding CurrentScenario}" />
            </TabItem>
            <TabItem Header="Customization">
                <views:CustomizationView DataContext="{Binding CurrentScenario}" />
            </TabItem>
            <TabItem Header="ListView Example">
                <views:ListViewFilterView DataContext="{Binding CurrentScenario}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>