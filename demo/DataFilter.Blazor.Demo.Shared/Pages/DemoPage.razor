@page "/demo"
@using DataFilter.Blazor.Components
@using DataFilter.Demo.Shared.Models
@using DataFilter.Demo.Shared.Services
@using Microsoft.AspNetCore.Components.Web
@using static DataFilter.Blazor.Components.DataFilterGrid<DataFilter.Demo.Shared.Models.Employee>

<h3>DataFilter Blazor Demo</h3>

<p>This demo showcases the Excel-like filtering capabilities in Blazor.</p>

<DataFilterGrid Items="@_data" Columns="@_columns" />

@code {
    // Intentionally a few thousand rows to validate performance/UX.
    private const long RowCount = 5000;

    private List<Employee> _data = new();
    private List<ColumnDefinition<Employee>> _columns = new();

    protected override void OnInitialized()
    {
        _data = EmployeeDataGenerator.Generate(RowCount);

        _columns = new List<ColumnDefinition<Employee>>
        {
            new ColumnDefinition<Employee> { Id = "Id", Title = "ID", PropertyName = "Id", Selector = x => x.Id, PropertyType = typeof(int) },
            new ColumnDefinition<Employee> { Id = "Name", Title = "Name", PropertyName = "Name", Selector = x => x.Name, PropertyType = typeof(string) },
            new ColumnDefinition<Employee> { Id = "Department", Title = "Department", PropertyName = "Department", Selector = x => x.Department, PropertyType = typeof(string) },
            new ColumnDefinition<Employee> { Id = "Country", Title = "Country", PropertyName = "Country", Selector = x => x.Country, PropertyType = typeof(string) },
            new ColumnDefinition<Employee> { Id = "Salary", Title = "Salary", PropertyName = "Salary", Selector = x => x.Salary, PropertyType = typeof(float) },
            new ColumnDefinition<Employee> { Id = "HireDate", Title = "Hire Date", PropertyName = "HireDate", Selector = x => x.HireDate, PropertyType = typeof(DateTime) },
            new ColumnDefinition<Employee> { Id = "Time", Title = "Time", PropertyName = "Time", Selector = x => x.Time, PropertyType = typeof(TimeSpan) },
            new ColumnDefinition<Employee> { Id = "IsActive", Title = "Active", PropertyName = "IsActive", Selector = x => x.IsActive, PropertyType = typeof(bool) },
        };
    }
}
