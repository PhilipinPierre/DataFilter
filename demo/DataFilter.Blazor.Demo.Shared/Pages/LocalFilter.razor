@page "/demo/local"
@using DataFilter.Blazor.Demo.Shared.State
@using DataFilter.Core.Models
@using DataFilter.Demo.Shared.Services
@inject DemoState State
@inject NavigationManager Navigation

<DemoShell OnClearFilters="HandleClearFilters" />

<div class="scenario-header">
    <h3>Scenario 1 — Local Filtering</h3>
    <p class="text-muted">All data is loaded locally. Filters are applied in-memory instantly.</p>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <strong>Filter pipeline (JSON preset)</strong>
        </div>

        <textarea class="form-control font-monospace" rows="8" @bind="_pipelineJson"></textarea>

        @if (!string.IsNullOrWhiteSpace(_jsonError))
        {
            <div class="text-danger mt-2">@_jsonError</div>
        }

        <div class="d-flex gap-2 mt-2">
            <button class="btn btn-outline-secondary" @onclick="SyncPipelineFromGrid">Sync from grid</button>
            <button class="btn btn-primary" @onclick="ApplyPipelineJson">Apply JSON</button>
        </div>
    </div>
</div>

<div class="grid-container">
    <DataFilterGrid @ref="_grid" Items="@_data" Columns="@_columns" />
</div>

@using DataFilter.Blazor.Demo.Shared.Helpers
...
@code {
    private DataFilterGrid<Employee>? _grid;
    private IEnumerable<Employee> _data => EmployeeDataGenerator.Employees;
    private List<DataFilterGrid<Employee>.ColumnDefinition<Employee>> _columns = ColumnHelper.GetDefaultColumns();
    private string _pipelineJson = @"{
  ""schemaVersion"": 1,
  ""rootCombineOperator"": ""And"",
  ""nodes"": [
    {
      ""kind"": ""criterion"",
      ""id"": ""demo-active"",
      ""isEnabled"": true,
      ""propertyName"": ""IsActive"",
      ""operator"": ""Equals"",
      ""value"": true
    }
  ]
}";
    private string? _jsonError;

    protected override void OnInitialized()
    {
        State.OnChange += StateChanged;
        if (!EmployeeDataGenerator.Employees.Any())
        {
            State.Regenerate();
        }
    }

    private void StateChanged() => StateHasChanged();

    private void HandleClearFilters()
    {
        _grid?.ClearFilters();
    }

    private void SyncPipelineFromGrid()
    {
        _jsonError = null;
        if (_grid == null) return;

        var snapshot = _grid.CreatePipelineSnapshotFromCurrentGrid();
        _pipelineJson = FilterPipelineJson.Serialize(snapshot);
    }

    private async Task ApplyPipelineJson()
    {
        _jsonError = null;
        if (_grid == null) return;

        try
        {
            FilterPipelineSnapshot snapshot = FilterPipelineJson.Deserialize(_pipelineJson);
            await _grid.ApplyPipelineSnapshotAsync(snapshot);
        }
        catch (Exception ex)
        {
            _jsonError = ex.Message;
        }
    }

    public void Dispose()
    {
        State.OnChange -= StateChanged;
    }
}
