<UserControl x:Class="DataFilter.Wpf.Demo.Views.CustomizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf.PopupHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:CustomizationScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="Scenario 4 — UI Customization" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,15" />
            <TextBlock Text="Change the toggle to customize colors dynamically. This demonstrates how the filtering UI can be themed to match your application's appearance." 
                       TextWrapping="Wrap" FontSize="14" Foreground="Gray"/>
            
            <CheckBox Content="Dark Theme" IsChecked="{Binding IsDarkTheme}" Margin="0,5"/>
            
            <TextBlock Text="In WPF, requested theme changes dynamically update the controls." 
                       TextWrapping="Wrap" FontSize="12" Foreground="Gray" />
        </StackPanel>

        <controls:FilterableDataGrid Grid.Column="1"
                                     ViewModel="{Binding GridViewModel}"
                                     ItemsSource="{Binding GridViewModel.FilteredItems}" 
                                     AutoGenerateColumns="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     FilterContext="{Binding GridViewModel.Context}" />
    </Grid>
</UserControl>
