<Window x:Class="DataFilter.Wpf.Demo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:DataFilter.Wpf.Demo.Views"
        xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
        mc:Ignorable="d"
        Title="DataFilter WPF Demo"
        Height="600"
        Width="1000"
        d:DataContext="{d:DesignInstance Type={x:Type viewmodels:MainViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,0">
            <TextBlock Text="Row Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox Text="{Binding RowCount, UpdateSourceTrigger=PropertyChanged}" Width="100" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Button Content="Regenerate Data" Command="{Binding RegenerateCommand}" Padding="10,2"/>
            <Button Content="Clear filters"
                    Command="{Binding ClearFiltersCommand}"
                    Padding="10,2" />
            <Separator Width="15" Opacity="0"/>
            <TextBlock Text="Language:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <ComboBox x:Name="LanguageCombo"
                      Width="220"
                      VerticalAlignment="Center"
                      Margin="0,0,0,0"/>
        </StackPanel>
        
        <TabControl Grid.Row="1" Margin="10" SelectedItem="{Binding SelectedTabControl, Mode=TwoWay}">
            <TabItem Header="Local Filtering">
                <views:LocalFilterView DataContext="{Binding LocalFilterScenario}" />
            </TabItem>
            <TabItem Header="Async Filtering">
                <views:AsyncFilterView DataContext="{Binding AsyncFilterScenario}" />
            </TabItem>
            <TabItem Header="Hybrid Filtering">
                <views:HybridFilterView DataContext="{Binding HybridFilterScenario}" />
            </TabItem>
            <TabItem Header="Customization">
                <views:CustomizationView DataContext="{Binding CustomizationScenario}" />
            </TabItem>
            <TabItem Header="ListView Example">
                <views:ListViewFilterView DataContext="{Binding ListViewScenario}" />
            </TabItem>
            <TabItem Header="CollectionView Example">
                <views:CollectionViewFilterView DataContext="{Binding CollectionViewScenario}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>