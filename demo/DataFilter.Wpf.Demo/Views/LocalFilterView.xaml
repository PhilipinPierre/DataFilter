<UserControl x:Class="DataFilter.Wpf.Demo.Views.LocalFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:LocalFilterScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto"
                           MaxHeight="400" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="10">
            <TextBlock Text="Scenario 1 — Local Filtering"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="All data is loaded locally. Filters are applied in-memory instantly against the collection."
                       FontSize="14"
                       Foreground="Gray" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="10,0,10,10"
                Padding="10"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="4">
            <StackPanel VerticalAlignment="Stretch">
                <TextBlock Text="Filter pipeline (JSON preset)"
                           FontWeight="Bold"
                           Margin="0,0,0,6" />
                <TextBox Text="{Binding PipelineJson, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="100"
                         FontFamily="Consolas"
                         FontSize="12" 
                         MaxHeight="300"/>
                <StackPanel Orientation="Horizontal"
                            Margin="0,8,0,0"
                            VerticalAlignment="Stretch">
                    <Button Content="Sync from grid"
                            Command="{Binding SyncPipelineFromGridCommand}"
                            Margin="0,0,8,0"
                            Padding="12,4" />
                    <Button Content="Apply JSON"
                            Command="{Binding ApplyPipelineJsonCommand}"
                            Padding="12,4" />
                </StackPanel>
            </StackPanel>
        </Border>

        <controls:FilterableDataGrid Grid.Row="2"
                                     ViewModel="{Binding GridViewModel}"
                                     ItemsSource="{Binding GridViewModel.FilteredItems}"
                                     AutoGenerateColumns="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     FilterContext="{Binding GridViewModel.Context}" />
    </Grid>
</UserControl>
