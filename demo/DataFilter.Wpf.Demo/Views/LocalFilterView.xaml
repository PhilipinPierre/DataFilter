<UserControl x:Class="DataFilter.Wpf.Demo.Views.LocalFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf.PopupHost"
             xmlns:wpf="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:LocalFilterScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto"
                           MaxHeight="400" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="10">
            <TextBlock Text="Scenario 1 — Local Filtering"
                       FontSize="20"
                       FontWeight="Bold" />
            <TextBlock Text="All data is loaded locally. Filters are applied in-memory instantly against the collection."
                       FontSize="14"
                       Foreground="Gray" />
        </StackPanel>

        <Expander Grid.Row="1"
                  Margin="10,0,10,10"
                  Padding="10"
                  BorderBrush="LightGray"
                  BorderThickness="1">
            <Expander.Header>
                <TextBlock Text="Filter pipeline preset"
                           FontWeight="Bold"/>
            </Expander.Header>
            <Expander.Content>
                <Grid MaxHeight="325">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Sync loads a mutable snapshot (WorkingSnapshot). Edit criteria/sort in code or via JSON, then apply."
                               TextWrapping="Wrap"
                               Foreground="Gray"
                               Margin="0,0,0,6"
                               Grid.Row="0"/>
                    <TextBox Text="{Binding PipelineJson, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="df-pipeline-json"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="100"
                             FontFamily="Consolas"
                             FontSize="12"
                             MaxHeight="300"
                             Grid.Row="1" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0"
                                VerticalAlignment="Stretch"
                                Grid.Row="2">
                        <Button Content="Sync from grid"
                                AutomationProperties.AutomationId="df-pipeline-sync"
                                Command="{Binding SyncPipelineFromGridCommand}"
                                Margin="0,0,8,0"
                                Padding="12,4" />
                        <Button Content="Apply JSON"
                                AutomationProperties.AutomationId="df-pipeline-apply"
                                Command="{Binding ApplyPipelineJsonCommand}"
                                Margin="0,0,8,0"
                                Padding="12,4" />
                        <Button Content="Apply snapshot"
                                Command="{Binding ApplyWorkingSnapshotCommand}"
                                Margin="0,0,8,0"
                                Padding="12,4" />
                        <Button Content="Add sample sort"
                                Command="{Binding AddSampleSortToWorkingSnapshotCommand}"
                                Padding="12,4" />
                    </StackPanel>
                </Grid>
            </Expander.Content>
        </Expander>

        <wpf:FilterGridChrome x:Name="GridChrome"
                              Grid.Row="2"
                              ShowFilterBar="True"
                              GridViewModel="{Binding GridViewModel}" />
    </Grid>
</UserControl>
