<UserControl x:Class="DataFilter.Wpf.Demo.Views.LocalFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:LocalFilterScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="Scenario 1 — Local Filtering" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="All data is loaded locally. Filters are applied in-memory instantly against the collection." FontSize="14" Foreground="Gray" />
        </StackPanel>

        <controls:FilterableDataGrid Grid.Row="1"
                                     ViewModel="{Binding GridViewModel}"
                                     ItemsSource="{Binding GridViewModel.FilteredItems}"
                                     AutoGenerateColumns="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     FilterContext="{Binding GridViewModel.Context}" />
    </Grid>
</UserControl>
