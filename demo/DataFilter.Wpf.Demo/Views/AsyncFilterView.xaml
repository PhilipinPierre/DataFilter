<UserControl x:Class="DataFilter.Wpf.Demo.Views.AsyncFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:AsyncFilterScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="Scenario 2 — Async Filtering" FontSize="20" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBlock Text="Fetches data from a mock API service, demonstrating background loading and UI responsiveness." FontSize="14" Foreground="Gray" Margin="0,0,0,5" />
            <Border Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" CornerRadius="4" Padding="10,5">
                <TextBlock Text="⏳  Async Data Loading Enabled" Foreground="White" FontWeight="SemiBold" />
            </Border>
        </StackPanel>
        <controls:FilterableDataGrid Grid.Row="1"
                                     ViewModel="{Binding GridViewModel}"
                                     ItemsSource="{Binding GridViewModel.FilteredItems}" 
                                     AutoGenerateColumns="True"
                                     EnableAsyncFetch="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     AsyncDataProvider="{Binding GridViewModel.AsyncDataProvider}"
                                     FilterContext="{Binding GridViewModel.Context}" />
    </Grid>
</UserControl>
