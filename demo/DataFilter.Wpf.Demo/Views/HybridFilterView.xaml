<UserControl x:Class="DataFilter.Wpf.Demo.Views.HybridFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:DataFilter.Wpf.Controls;assembly=DataFilter.Wpf.PopupHost"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:viewmodels="clr-namespace:DataFilter.Wpf.Demo.ViewModels"
             d:DataContext="{d:DesignInstance Type={x:Type viewmodels:HybridFilterScenarioViewModel}, IsDesignTimeCreatable=True}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="10">
            <TextBlock Text="Scenario 3 — Hybrid Filtering" FontSize="20" FontWeight="Bold" Margin="0,0,0,5" />
            <TextBlock Text="Combines local filtering logic with asynchronous fetching of distinct values for the filter UI." FontSize="14" Foreground="Gray" Margin="0,0,0,5" />
            <Border Background="DarkGreen" CornerRadius="4" Padding="10,5">
                <TextBlock Text="🔀  Hybrid mode — local results + async distinct values" Foreground="White" FontWeight="SemiBold" />
            </Border>
        </StackPanel>
        <!-- Hybrid mode: Local filtering with EnableAsyncFetch=false, but AsyncDataProvider bound to fetch distinct values -->
        <controls:FilterableDataGrid Grid.Row="1"
                                     ViewModel="{Binding GridViewModel}"
                                     ItemsSource="{Binding GridViewModel.FilteredItems}"
                                     AutoGenerateColumns="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     EnableAsyncFetch="False"
                                     AsyncDataProvider="{Binding GridViewModel.AsyncDataProvider}"
                                     FilterContext="{Binding GridViewModel.Context}" />
    </Grid>
</UserControl>
