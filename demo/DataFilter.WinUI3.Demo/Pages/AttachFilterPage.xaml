<Page
    x:Class="DataFilter.WinUI3.Demo.Pages.AttachFilterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="10" Spacing="5">
            <TextBlock Text="Attach demo — ListView header adapter (no custom control)" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="This uses ListViewFilterHeaderAdapter to inject filter buttons into an existing ListView header." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <ListView x:Name="EmployeesList"
                  Grid.Row="1"
                  Margin="10,0,10,10"
                  ItemsSource="{x:Bind ViewModel.GridViewModel.FilteredItems, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Id}" Width="50" />
                        <TextBlock Text="{Binding Name}" Width="150" />
                        <TextBlock Text="{Binding Department}" Width="150" />
                        <TextBlock Text="{Binding Country}" Width="150" />
                        <TextBlock Text="{Binding Time}" Width="100" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

