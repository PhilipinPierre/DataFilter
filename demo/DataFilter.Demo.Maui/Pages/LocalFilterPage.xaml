<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DataFilter.Maui.Controls;assembly=DataFilter.Maui"
             x:Class="DataFilter.Maui.Demo.Pages.LocalFilterPage"
             Title="Local Filtering">

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12" Spacing="2">
            <Label Text="Scenario 1 — Local Filtering"
                   FontSize="16" FontAttributes="Bold" />
            <Label Text="All data is loaded locally. Filters are applied in-memory instantly against the collection."
                   FontSize="13" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
        </VerticalStackLayout>
        <controls:FilterableDataGrid Grid.Row="1"
                                     ViewModel="{Binding ViewModel.GridViewModel}" />
    </Grid>
</ContentPage>
