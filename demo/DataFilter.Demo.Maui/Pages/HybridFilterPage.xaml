<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DataFilter.Maui.Controls;assembly=DataFilter.Maui"
             x:Class="DataFilter.Maui.Demo.Pages.HybridFilterPage"
             Title="Hybrid Filtering">

    <Grid RowDefinitions="Auto,Auto,Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="16,12" Spacing="2">
            <Label Text="Scenario 3 — Hybrid Filtering"
                   FontSize="16" FontAttributes="Bold" />
            <Label Text="Local data for instant row filtering; async API for distinct filter values in the popup."
                   FontSize="13" TextColor="{AppThemeBinding Light=Gray, Dark=LightGray}" />
        </VerticalStackLayout>
        <Frame Grid.Row="1" Margin="16,0,16,8" Padding="10,6"
               BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1A3D2B}"
               BorderColor="{AppThemeBinding Light=#A5D6A7, Dark=#2E7D55}"
               CornerRadius="6">
            <Label Text="🔀  Hybrid mode — local results + async distinct values from API"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}" />
        </Frame>

        <!-- Header Row -->
        <Border Grid.Row="2" Style="{StaticResource DataGridHeaderStyle}" Margin="8,0">
            <HorizontalStackLayout Spacing="0" VerticalOptions="Center">
                <Button Text="ID 🔍" WidthRequest="70" Clicked="OnFilterId" Style="{StaticResource HeaderButtonStyle}" />
                <Button Text="Name 🔍" WidthRequest="150" Clicked="OnFilterName" Style="{StaticResource HeaderButtonStyle}" />
                <Button Text="Dept 🔍" WidthRequest="120" Clicked="OnFilterDept" Style="{StaticResource HeaderButtonStyle}" />
                <Button Text="Country 🔍" WidthRequest="120" Clicked="OnFilterCountry" Style="{StaticResource HeaderButtonStyle}" />
            </HorizontalStackLayout>
        </Border>

        <ListView Grid.Row="3" Margin="8"
                  ItemsSource="{Binding ViewModel.GridViewModel.FilteredItems}"
                  ItemTemplate="{StaticResource EmployeeItemTemplate}"
                  SeparatorVisibility="Default"
                  SelectionMode="None" />

        <!-- Popup Overlay -->
        <BoxView x:Name="PopupOverlay" Grid.Row="0" Grid.RowSpan="4" BackgroundColor="#80000000" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnClosePopup" />
            </BoxView.GestureRecognizers>
        </BoxView>
        <Frame x:Name="PopupFrame" Grid.Row="3" VerticalOptions="Start" HorizontalOptions="Center" Margin="20" Padding="0" IsVisible="False" HasShadow="True" CornerRadius="8" BorderColor="Gray">
            <ContentView x:Name="PopupContainer" />
        </Frame>
    </Grid>
</ContentPage>
